generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChannelType {
  WHATSAPP
  MESSENGER
  COMMENTS
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum LeadStatus {
  NEW
  ORDER_PENDING
  CONTACTED
  CLOSED
}

enum UserRole {
  ADMIN
  CLIENT
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name             String?
  slug             String?  @unique
  email            String?
  isActive         Boolean   @default(true) @map("is_active")
  subscriptionEnd DateTime? @map("subscription_end")

  users         User[]
  products      Product[]
  faqs          Faq[]
  conversations Conversation[]
  memories      ConversationMemory[]
  productViews  ProductView[]
  productRecommendations ProductRecommendation[]
  productAffinities ProductAffinity[]
  leads         Lead[]
  orders        Order[]
  botSettings        BotSettings?
  whatsappAccounts   WhatsappAccount[]

  @@map("tenants")
}

model WhatsappAccount {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  metaPhoneNumberId    String   @unique @map("meta_phone_number_id")
  metaWabaId           String?  @map("meta_waba_id")
  displayPhoneNumber   String?  @map("display_phone_number")
  accessTokenEncrypted String   @map("access_token_encrypted")
  /** Last 4 chars of the access token (for UI masking only). */
  accessTokenLast4    String?  @map("access_token_last_4") @db.VarChar(4)
  verifyToken          String?  @map("verify_token")
  metaAppSecret        String?  @map("meta_app_secret")
  status               String   @default("active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([metaWabaId])
  @@map("whatsapp_accounts")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email    String   @unique
  password String
  role     UserRole @default(CLIENT)

  @@index([tenantId])
  @@map("users")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  price       Float
  imageUrls   String[] @default([]) @map("image_urls")
  keywords    String[] @default([])
  isActive    Boolean  @default(true) @map("is_active")

  views      ProductView[]
  affinities ProductAffinity[]

  @@index([tenantId, isActive])
  @@map("products")
}

model Faq {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  questionAr String   @map("question_ar")
  questionEn String   @map("question_en")
  answerAr   String   @map("answer_ar")
  answerEn   String   @map("answer_en")
  keywordsAr String[] @default([]) @map("keywords_ar")
  keywordsEn String[] @default([]) @map("keywords_en")
  isActive   Boolean  @default(true) @map("is_active")
  priority   Int      @default(0)

  @@index([tenantId, isActive])
  @@map("faqs")
}

model Lead {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String?
  phone    String?
  interest String?
  status   LeadStatus @default(NEW)
  lastMessage String? @map("last_message")
  orderStep   String? @map("order_step")
  orderPhone  String? @map("order_phone")
  size        String? @map("size")
  location    String? @map("location")

  @@index([tenantId])
  @@index([tenantId, phone])
  @@unique([tenantId, phone])
  @@map("leads")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  channelType ChannelType @map("channel_type")

  externalUserId   String    @map("external_user_id")
  externalUserName String?   @map("external_user_name")
  lastMessageAt    DateTime? @map("last_message_at")
  lastFollowUpAt   DateTime? @map("last_follow_up_at")
  leadStatus       String    @default("new") @map("lead_status")

  salesStep String @default("idle") @map("sales_step")
  tempData  Json?  @map("temp_data")

  /** Locked on first user message: ar | en. Used for FAQ + system copy. */
  language String @default("ar")

  messages Message[]
  memories ConversationMemory[]
  productViews ProductView[]
  productRecommendations ProductRecommendation[]

  @@index([tenantId, externalUserId])
  @@map("conversations")
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction MessageDirection
  content   String
  metadata  Json?

  @@index([conversationId])
  @@map("messages")
}

model BotSettings {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @unique @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  aiEnabled       Boolean @default(false) @map("ai_enabled")
  fallbackMessage String  @default("سيتم الرد عليك قريبًا") @map("fallback_message")
  welcomeMessage  String? @map("welcome_message")
  welcomeImages   String[] @default([]) @map("welcome_images")
  welcomeVideos   String[] @default([]) @map("welcome_videos")

  @@map("bot_settings")
}

model ConversationMemory {
  id             String @id @default(uuid()) @db.Uuid

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  messageText String @map("message_text") @db.Text
  embedding   Json?  @map("embedding")
  role        String @map("role")
  timestamp   DateTime @default(now()) @map("timestamp")

  @@unique([conversationId, timestamp])
  @@index([tenantId])
  @@index([conversationId])
  @@index([timestamp])
  @@map("conversation_memories")
}

model ProductView {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  viewDuration    Int     @map("view_duration")
  mentionedInChat Boolean @default(true) @map("mentioned_in_chat")
  orderPlaced     Boolean @default(false) @map("order_placed")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([conversationId, productId])
  @@index([tenantId])
  @@index([productId])
  @@index([createdAt])
  @@map("product_views")
}

model ProductRecommendation {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  recommendedProducts Json @map("recommended_products")
  clickedProductId    String? @map("clicked_product_id") @db.Uuid
  clickedAt           DateTime? @map("clicked_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("product_recommendations")
}

model ProductAffinity {
  id String @id @default(uuid()) @db.Uuid

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  associatedKeywords String[] @map("associated_keywords")

  totalMentions  Int   @default(0) @map("total_mentions")
  totalOrders    Int   @default(0) @map("total_orders")
  conversionRate Float @default(0) @map("conversion_rate")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, productId])
  @@index([tenantId])
  @@index([conversionRate])
  @@map("product_affinities")
}

model Order {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // بيانات العميل
  customerName    String  @map("customer_name")
  customerPhone   String  @map("customer_phone")
  customerAddress String  @map("customer_address")
  locationUrl     String? @map("location_url")
  notes           String? @map("notes")

  // المنتجات (JSON array)
  // [{ productId, name, price, quantity }]
  items     Json    @default("[]")
  total     Float   @default(0)

  // الحالة
  status    String  @default("pending")
  // pending / confirmed / cancelled / delivered

  // مصدر الطلب
  sourcePhone String? @map("source_phone")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([createdAt])
  @@map("orders")
}

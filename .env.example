#
# ملاحظة مهمة / Important:
# هذا الملف مثال فقط. لا تضع أي قيم حساسة هنا.
# انسخ هذا الملف إلى .env محليًا (غير متتبع) واملأ القيم.
#

#
# Application / التطبيق
#

# بيئة التشغيل: development | test | production
NODE_ENV=development

# بورت تشغيل الـ API
PORT=3000

# اسم التطبيق (للاستخدام في logs/metadata)
APP_NAME=messaging-automation-platform

# Base URL عام للتطبيق (مستخدم لبناء روابط مثل روابط الصور المرفوعة).
# مثال: http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000

#
# Auth (JWT) / المصادقة
#

# سر JWT (ضع قيمة قوية في الإنتاج: 32+ حرف، عشوائية)
JWT_SECRET=

# مدة صلاحية access token بالثواني (مثال: 604800 = 7 أيام)
JWT_EXPIRES_SEC=604800

#
# PostgreSQL (Prisma) / قاعدة البيانات
#

# رابط اتصال PostgreSQL بصيغة Prisma
# مثال: postgresql://user:pass@localhost:5432/dbname?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/messaging_automation?schema=public

#
# Redis / ريديس
#

# BullMQ outbound send queue يعتمد على Redis (مطلوب عند تشغيل التطبيق).
REDIS_URL=redis://localhost:6379

#
# Rate limits / تحديد المعدلات (لكل tenant في نافذة 60 ثانية)
#

# أقصى عدد requests للويبهوك في الدقيقة لكل tenant
RATE_LIMIT_WEBHOOK_PER_MINUTE=60

# أقصى عدد رسائل outbound في الدقيقة لكل tenant
RATE_LIMIT_OUTBOUND_PER_MINUTE=300

#
# WhatsApp Cloud API (Meta) / واتساب (ميتا)
#

# سر تطبيق Meta (مطلوب للتحقق من توقيع webhooks: X-Hub-Signature-256)
META_APP_SECRET=

# verify token افتراضي لعملية التحقق GET /whatsapp/webhook
# يستخدم فقط إذا لم يجد النظام verifyToken مطابق داخل WhatsappAccount في قاعدة البيانات.
DEFAULT_VERIFY_TOKEN=your_verify_token

# مفتاح تشفير توكنات WhatsApp المخزنة في DB (يفضل: base64 لـ 32 bytes بالضبط)
# مثال توليد (Node): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WHATSAPP_TOKEN_ENCRYPTION_KEY=

# رقم لاختبار الإرسال (اختياري) بصيغة دولية بدون +
# مثال: 201234567890
WHATSAPP_TEST_TO=

# Meta Commerce catalog id (اختياري) لإرسال interactive product_list
# You must configure your WhatsApp Business catalog in Meta first.
WHATSAPP_CATALOG_ID=

#
# OpenAI (اختياري) / الذكاء الاصطناعي
#

# API key لـ OpenAI (اتركه فارغًا لتعطيل AI fallback)
OPENAI_API_KEY=

# اسم الموديل (مثال: gpt-4.1-mini أو حسب ما تستخدمه في كودك)
OPENAI_MODEL=gpt-4o-mini

# Embeddings model (اختياري) - model name for semantic memory embeddings
# Example: text-embedding-3-small
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# timeout بالميلي ثانية لاستدعاءات OpenAI
OPENAI_TIMEOUT_MS=15000

ANTHROPIC_API_KEY=

#
# Anthropic model id (اختياري)
# ممكن تحط موديل واحد أو قائمة موديلات مفصولة بفواصل علشان النظام يجرب لحد ما يلاقي موديل متاح لحسابك.
# أمثلة (قد تختلف حسب حسابك):
# ANTHROPIC_MODEL=claude-haiku-4-5,claude-sonnet-4-6,claude-opus-4-7
ANTHROPIC_MODEL=

# Baileys (WhatsApp Web) - enable WhatsApp via QR login
BAILEYS_ENABLED=true

# Baileys tenant routing (مهم في multi-tenant):
# حط هنا tenantId اللي أنت فاتح بيه الداشبورد علشان المحادثات/المنتجات/الـ FAQ تتسجل وتظهر صح.
BAILEYS_TENANT_ID=
